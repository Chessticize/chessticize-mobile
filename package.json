{
  "name": "chessticize-mobile",
  "version": "0.1.0",
  "private": true,
  "license": "GPL-3.0-or-later",
  "type": "module",
  "packageManager": "pnpm@11.1.2",
  "scripts": {
    "test": "node --experimental-strip-types --test packages/core/test/*.test.ts packages/storage/test/*.test.ts packages/storage/test/*.test.mjs apps/cli/test/*.test.ts scripts/*.test.mjs",
    "test:unit": "node --experimental-strip-types --test packages/core/test/*.test.ts",
    "test:integration": "node --experimental-strip-types --test packages/storage/test/*.test.ts packages/storage/test/*.test.mjs",
    "test:e2e": "node --experimental-strip-types --test apps/cli/test/*.test.ts",
    "test:tooling": "node --test scripts/*.test.mjs && pnpm mobile:data-egress-audit",
    "app-store:preflight": "node scripts/app-store-preflight.mjs",
    "app-store:signing-readiness": "node scripts/app-store-signing-readiness.mjs",
    "app-store:third-party-audit": "node scripts/app-store-third-party-audit.mjs",
    "mobile:data-egress-audit": "node scripts/mobile-data-egress-audit.mjs",
    "app-store:screenshot-audit": "node scripts/app-store-screenshot-audit.mjs",
    "app-store:release-manifest": "node scripts/app-store-release-manifest.mjs",
    "app-store:testflight-evidence": "node scripts/app-store-testflight-evidence.mjs",
    "process:validate": "node scripts/validate-development-process.mjs",
    "generate:offline-puzzles": "node --experimental-strip-types scripts/generate-offline-puzzle-fixture.mjs",
    "benchmark:multi-theme-query": "node --experimental-strip-types scripts/benchmark-multi-theme-query.mjs",
    "update:offline-puzzle-presolve": "node --experimental-strip-types scripts/update-offline-puzzle-pack-presolve.mjs",
    "typecheck": "tsc --noEmit",
    "mobile:start": "pnpm --filter ChessticizeMobile start",
    "mobile:ios": "pnpm --filter ChessticizeMobile ios",
    "mobile:lint": "pnpm --filter ChessticizeMobile lint",
    "mobile:test": "pnpm --filter ChessticizeMobile test",
    "mobile:typecheck": "pnpm --filter ChessticizeMobile typecheck",
    "mobile:storybook": "pnpm --filter ChessticizeMobileLab storybook",
    "mobile:storybook:build": "pnpm --filter ChessticizeMobileLab build-storybook",
    "mobile:lab:typecheck": "pnpm --filter ChessticizeMobileLab typecheck",
    "mobile:lab:test": "pnpm --filter ChessticizeMobileLab test",
    "mobile:lab:check-markers": "pnpm --filter ChessticizeMobileLab check:new-scenarios",
    "mobile:lab:validate": "pnpm --filter ChessticizeMobileLab validate",
    "mobile:doctor:ios": "pnpm --filter ChessticizeMobile doctor:ios",
    "mobile:doctor:android": "pnpm --filter ChessticizeMobile doctor:android",
    "mobile:install:android-sdk": "pnpm --filter ChessticizeMobile install:android-sdk",
    "mobile:e2e:build:ios": "pnpm --filter ChessticizeMobile e2e:build:ios",
    "mobile:e2e:build:ios:release": "pnpm --filter ChessticizeMobile e2e:build:ios:release",
    "mobile:e2e:test:ios": "pnpm --filter ChessticizeMobile e2e:test:ios",
    "mobile:e2e:test:ios:ci": "pnpm --filter ChessticizeMobile e2e:test:ios:ci",
    "mobile:e2e:store-assets:ios": "pnpm --filter ChessticizeMobile e2e:store-assets:ios",
    "mobile:e2e:store-assets:ios:release": "pnpm --filter ChessticizeMobile e2e:store-assets:ios:release",
    "mobile:e2e:adaptive-layout:ios": "pnpm --filter ChessticizeMobile e2e:adaptive-layout:ios",
    "mobile:e2e:adaptive-layout:android": "pnpm --filter ChessticizeMobile e2e:adaptive-layout:android",
    "mobile:e2e:build:android": "pnpm --filter ChessticizeMobile e2e:build:android",
    "mobile:e2e:test:android": "pnpm --filter ChessticizeMobile e2e:test:android",
    "mobile:e2e:test:android:ci": "pnpm --filter ChessticizeMobile e2e:test:android:ci",
    "mobile:validate:android:matrix": "pnpm --filter ChessticizeMobile validate:android:matrix",
    "mobile:verify:android:abis": "pnpm --filter ChessticizeMobile verify:android:abis",
    "mobile:verify:android:backup": "pnpm --filter ChessticizeMobile verify:android:backup",
    "mobile:verify:android:release": "pnpm --filter ChessticizeMobile verify:android:release",
    "mobile:verify:android:github-release": "pnpm --filter ChessticizeMobile verify:android:github-release",
    "fetch:core-pack": "node scripts/fetch-core-pack.mjs"
  },
  "dependencies": {
    "chess.js": "^1.4.0"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "typescript": "^5.9.0"
  }
}
