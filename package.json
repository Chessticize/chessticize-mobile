{
  "name": "chessticize-mobile",
  "version": "0.1.0",
  "private": true,
  "license": "GPL-3.0-or-later",
  "type": "module",
  "packageManager": "pnpm@11.1.2",
  "scripts": {
    "test": "node --experimental-strip-types --test packages/core/test/*.test.ts packages/storage/test/*.test.ts packages/storage/test/*.test.mjs apps/cli/test/*.test.ts",
    "test:unit": "node --experimental-strip-types --test packages/core/test/*.test.ts",
    "test:integration": "node --experimental-strip-types --test packages/storage/test/*.test.ts packages/storage/test/*.test.mjs",
    "test:e2e": "node --experimental-strip-types --test apps/cli/test/*.test.ts",
    "app-store:preflight": "node scripts/app-store-preflight.mjs",
    "app-store:signing-readiness": "node scripts/app-store-signing-readiness.mjs",
    "app-store:third-party-audit": "node scripts/app-store-third-party-audit.mjs",
    "app-store:screenshot-audit": "node scripts/app-store-screenshot-audit.mjs",
    "app-store:release-manifest": "node scripts/app-store-release-manifest.mjs",
    "app-store:testflight-evidence": "node scripts/app-store-testflight-evidence.mjs",
    "generate:offline-puzzles": "node --experimental-strip-types scripts/generate-offline-puzzle-fixture.mjs",
    "update:offline-puzzle-presolve": "node --experimental-strip-types scripts/update-offline-puzzle-pack-presolve.mjs",
    "typecheck": "tsc --noEmit",
    "mobile:start": "pnpm --filter ChessticizeMobile start",
    "mobile:ios": "pnpm --filter ChessticizeMobile ios",
    "mobile:test": "pnpm --filter ChessticizeMobile test",
    "mobile:typecheck": "pnpm --filter ChessticizeMobile typecheck",
    "mobile:doctor:ios": "pnpm --filter ChessticizeMobile doctor:ios",
    "mobile:e2e:build:ios": "pnpm --filter ChessticizeMobile e2e:build:ios",
    "mobile:e2e:test:ios": "pnpm --filter ChessticizeMobile e2e:test:ios",
    "mobile:e2e:store-assets:ios": "pnpm --filter ChessticizeMobile e2e:store-assets:ios",
    "fetch:core-pack": "node scripts/fetch-core-pack.mjs"
  },
  "dependencies": {
    "chess.js": "^1.4.0"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "typescript": "^5.9.0"
  }
}
