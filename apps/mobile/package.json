{
  "name": "ChessticizeMobile",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "lint": "eslint .",
    "start": "react-native start",
    "test": "jest",
    "typecheck": "tsc --noEmit",
    "doctor:ios": "scripts/ios-doctor.sh",
    "e2e:build:ios": "detox build --configuration ios.sim.debug",
    "e2e:test:ios": "detox test --configuration ios.sim.debug",
    "e2e:test:ios:ci": "detox test --configuration ios.sim.debug --cleanup",
    "e2e:store-assets:ios": "CHESSTICIZE_CAPTURE_STORE_ASSETS=1 detox test --configuration ios.sim.debug --artifacts-location artifacts/store-assets e2e/store-assets.e2e.js",
    "e2e:adaptive-layout:ios": "CHESSTICIZE_CAPTURE_ADAPTIVE_LAYOUT=1 detox test --configuration ios.sim.debug --artifacts-location artifacts/adaptive-layout e2e/adaptive-layout.e2e.js"
  },
  "dependencies": {
    "@op-engineering/op-sqlite": "17.1.1",
    "@shopify/react-native-skia": "^2.6.5",
    "react": "19.2.3",
    "react-native": "0.86.0",
    "react-native-chessboard": "0.2.0",
    "react-native-gesture-handler": "^3.0.2",
    "react-native-reanimated": "^4.4.1",
    "react-native-safe-area-context": "^5.5.2",
    "react-native-worklets": "^0.9.2"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/preset-env": "^7.25.3",
    "@babel/runtime": "^7.25.0",
    "@react-native-community/cli": "20.1.0",
    "@react-native-community/cli-platform-android": "20.1.0",
    "@react-native-community/cli-platform-ios": "20.1.0",
    "@react-native/babel-preset": "0.86.0",
    "@react-native/eslint-config": "0.86.0",
    "@react-native/jest-preset": "0.86.0",
    "@react-native/metro-config": "0.86.0",
    "@react-native/typescript-config": "0.86.0",
    "@testing-library/react-native": "14.0.0",
    "@types/jest": "^29.5.14",
    "@types/react": "^19.2.0",
    "@types/react-test-renderer": "^19.1.0",
    "babel-jest": "29.7.0",
    "detox": "20.51.4",
    "eslint": "^8.19.0",
    "expect": "29.7.0",
    "jest": "^29.7.0",
    "jest-circus": "^29.7.0",
    "prettier": "2.8.8",
    "react-test-renderer": "19.2.3",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">= 22.11.0"
  }
}
