<?xml version="1.0" encoding="utf-8"?>
<!--
  API 24-27 cannot advertise client-side encryption or D2D transport flags.
  Fail closed on those releases so progress is never sent to unencrypted cloud
  backup. API 28+ selects the qualified allowlist in res/xml-v28.
-->
<full-backup-content>
    <exclude domain="root" path="." />
    <exclude domain="file" path="." />
    <exclude domain="database" path="." />
    <exclude domain="sharedpref" path="." />
    <exclude domain="external" path="." />
    <exclude domain="device_root" path="." />
    <exclude domain="device_file" path="." />
    <exclude domain="device_database" path="." />
    <exclude domain="device_sharedpref" path="." />
</full-backup-content>
