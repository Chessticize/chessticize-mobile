<?xml version="1.0" encoding="utf-8"?>
<!--
  API 31+ separates cloud backup from device transfer. Exact database-file
  allowlists exclude bundled puzzles, engine assets, preferences, logs,
  generated/test data, and every other file by default. No cross-platform
  transfer section is declared.
-->
<data-extraction-rules>
    <cloud-backup disableIfNoEncryptionCapabilities="true">
        <include domain="database" path="chessticize-mobile.sqlite" />
        <include domain="database" path="chessticize-mobile.sqlite-journal" />
        <include domain="database" path="chessticize-mobile.sqlite-wal" />
    </cloud-backup>
    <device-transfer>
        <include domain="database" path="chessticize-mobile.sqlite" />
        <include domain="database" path="chessticize-mobile.sqlite-journal" />
        <include domain="database" path="chessticize-mobile.sqlite-wal" />
    </device-transfer>
</data-extraction-rules>
