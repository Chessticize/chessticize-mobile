<?xml version="1.0" encoding="utf-8"?>
<!--
  API 31+ separates cloud backup from device transfer. Android expands each
  database include to its real -journal and -wal sidecars, so the exact
  main-database allowlist excludes recursive sidecar suffixes, bundled puzzles,
  engine assets, preferences, logs, generated/test data, and every other file
  by default. No cross-platform transfer section is declared.
-->
<data-extraction-rules>
    <cloud-backup disableIfNoEncryptionCapabilities="true">
        <include domain="database" path="chessticize-mobile.sqlite" />
    </cloud-backup>
    <device-transfer>
        <include domain="database" path="chessticize-mobile.sqlite" />
    </device-transfer>
</data-extraction-rules>
